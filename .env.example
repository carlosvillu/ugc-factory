# Variables de entorno de DESARROLLO (T0.2). Copia a `.env` y ajusta:
#   cp .env.example .env
# `.env` está gitignored (puede contener credenciales reales). Este `.env.example`
# se committea con valores de ejemplo — NUNCA secretos reales.
#
# El compose de desarrollo (docker-compose.dev.yml) levanta Postgres; web y worker
# corren en el host con `pnpm dev` y leen ESTE fichero raíz: sus scripts `dev`
# cargan `../../.env` (`--env-file-if-exists`), así hay UN solo `.env` — el mismo
# que compose usa para las variables `${POSTGRES_*}`. Un único origen de config.
#
# NOTA: si cambias POSTGRES_PORT, actualiza también el puerto de DATABASE_URL a
# mano — es un literal, no interpola POSTGRES_PORT.

# ── Postgres (docker-compose.dev.yml) ────────────────────────────────────────
# Estas tres alimentan tanto al contenedor (POSTGRES_*) como a DATABASE_URL.
POSTGRES_USER=ugc
POSTGRES_PASSWORD=ugc
POSTGRES_DB=ugc
POSTGRES_PORT=5432

# Cadena de conexión que consumen web (/api/health) y worker (bootstrap) para el
# ping de Postgres — y, desde T0.3, el pool de Drizzle y las migraciones. Debe
# coincidir con las credenciales de arriba y el puerto expuesto.
DATABASE_URL=postgres://ugc:ugc@localhost:5432/ugc

# ── Observabilidad (T0.1) ────────────────────────────────────────────────────
# Nivel de log de pino (trace|debug|info|warn|error|silent). LOG_PRETTY=1 activa
# pino-pretty para humanos (solo en NODE_ENV=development).
LOG_LEVEL=info
# LOG_PRETTY=1

# ── Auth single-user (T0.4, PRD §19.2) ───────────────────────────────────────
# APP_MASTER_KEY es la ÚNICA credencial de cifrado en env: firma las cookies de
# sesión (y cifrará el resto de secretos en app_setting). El arranque de web
# REVIENTA si falta (fail-fast). Genera una aleatoria larga, p. ej.:
#   openssl rand -hex 32
APP_MASTER_KEY=change-me-genera-una-con-openssl-rand-hex-32
# Contraseña de bootstrap: se hashea (scrypt) y se siembra en app_setting en el
# PRIMER arranque contra la BD, solo si aún no hay hash (idempotente, nunca
# sobrescribe). Cambiarla después NO re-siembra: el hash queda congelado.
AUTH_BOOTSTRAP_PASSWORD=cambia-esta-contrasena-de-acceso
# Rate limit del login (por IP, ventana deslizante). Con MAX_ATTEMPTS=2 el 3.er
# password incorrecto ya devuelve 429 (fencepost: assert bloquea al ver 2 fallos).
# Ventana corta para que un bloqueo se auto-limpie sin esperar (un acierto también
# limpia el contador).
LOGIN_MAX_ATTEMPTS=2
LOGIN_WINDOW_MS=60000

# ── Almacenamiento de assets (T0.5, PRD §19.2) ───────────────────────────────
# Raíz del StorageAdapter local: dónde viven los artefactos binarios del pipeline
# (assets subidos/generados). El endpoint GET /api/assets/:id/download sirve desde
# aquí. Default de PRODUCCIÓN si se omite: /data/assets (montado en el VPS). En dev
# apunta a un path ESCRIBIBLE del host (no /data, que pediría root). Los tests y el
# stack E2E usan su propio tmpdir e ignoran esta variable.
#
# IMPORTANTE: usa una ruta ABSOLUTA. El adaptador resuelve la raíz contra el cwd
# del proceso; un path relativo (`./x`) resuelve distinto según desde dónde
# arranque web vs. el script de smoke, y el fichero subido quedaría "invisible"
# para la descarga. El smoke (`pnpm smoke:assets`) exige que web se haya arrancado
# con EXACTAMENTE este mismo ASSETS_DIR absoluto.
ASSETS_DIR=/tmp/ugc-assets-dev
