# Variables de entorno de DESARROLLO (T0.2). Copia a `.env` y ajusta:
#   cp .env.example .env
# `.env` está gitignored (puede contener credenciales reales). Este `.env.example`
# se committea con valores de ejemplo — NUNCA secretos reales.
#
# El compose de desarrollo (docker-compose.dev.yml) levanta Postgres; web y worker
# corren en el host con `pnpm dev` y leen ESTE fichero raíz: sus scripts `dev`
# cargan `../../.env` (`--env-file-if-exists`), así hay UN solo `.env` — el mismo
# que compose usa para las variables `${POSTGRES_*}`. Un único origen de config.
#
# NOTA: si cambias POSTGRES_PORT, actualiza también el puerto de DATABASE_URL a
# mano — es un literal, no interpola POSTGRES_PORT.

# ── Postgres (docker-compose.dev.yml) ────────────────────────────────────────
# Estas tres alimentan tanto al contenedor (POSTGRES_*) como a DATABASE_URL.
POSTGRES_USER=ugc
POSTGRES_PASSWORD=ugc
POSTGRES_DB=ugc
POSTGRES_PORT=5432

# Cadena de conexión que consumen web (/api/health) y worker (bootstrap) para el
# ping de Postgres — y, desde T0.3, el pool de Drizzle y las migraciones. Debe
# coincidir con las credenciales de arriba y el puerto expuesto.
DATABASE_URL=postgres://ugc:ugc@localhost:5432/ugc

# ── Observabilidad (T0.1) ────────────────────────────────────────────────────
# Nivel de log de pino (trace|debug|info|warn|error|silent). LOG_PRETTY=1 activa
# pino-pretty para humanos (solo en NODE_ENV=development).
LOG_LEVEL=info
# LOG_PRETTY=1
