{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  // espejo verbatim del DS de Claude Design + evidencia de cierre de tareas (incl.
  // scripts .ts del verifier): artefactos, no código del grafo de imports
  "ignore": ["docs/design-system/**", "docs/verifications/**"],
  "workspaces": {
    ".": {},
    "apps/web": {
      // los plugins de knip detectan Next (app router) y Vitest solos. El plugin
      // de Playwright se activa con @playwright/test en devDependencies y toma
      // playwright.config.ts + e2e/**/*.spec.ts como entries.
      // Entries que knip no rastrea por sí solo:
      //  - e2e-stack.ts: referenciado SOLO como string en webServer.command de
      //    playwright.config.ts (si no, él y su import de startPostgresContainer
      //    quedarían "unused").
      //  - auth.setup.ts: el setup project de Playwright (testMatch por regex); el
      //    plugin de knip solo toma *.spec.ts como entries, no el setup.
      "entry": ["scripts/e2e-stack.ts", "e2e/auth.setup.ts"]
      // pg ya NO se ignora: desde T0.10 el route handler del stream SSE
      // (runs/[id]/events) importa `Client` de 'pg' DIRECTO (conexión dedicada en
      // LISTEN), así que knip lo ve como dependency usada. Antes solo se declaraba
      // para forzar su externalización del server bundle (transitiva de @ugc/db);
      // ese motivo sigue vigente, pero ahora hay además un import directo que lo
      // justifica sin ignore. tsx tampoco se ignora: `smoke:assets` lo invoca.
    },
    "apps/worker": {
      // pino y pg no se importan directo (pino vía @ugc/core; pg vía @ugc/db),
      // pero el bundle de tsup los deja external: el artefacto dist/ los requiere
      // en runtime. Declararlos como dependency es lo que fuerza esa
      // externalización (sin ellos, tsup inlinea pg CJS en ESM y dist/ no arranca).
      // sharp, ídem (llega vía @ugc/core y @ugc/services): es un módulo NATIVO y
      // sin declararlo tsup lo inlineaba SIN sus binarios — el boot del worker en
      // modo prod crasheaba (detectado en T0.13, primera vez que se probó).
      "ignoreDependencies": ["pino", "pg", "sharp"]
    },
    "packages/core": {
      // pino-pretty solo se referencia como string de transport en makeLogger
      // (observability.md §2): knip no puede verlo en el grafo de imports.
      // El CLI `pnpm compile:prompt` (scripts/compile-prompt-demo.ts, T3.5) ya lo toma
      // knip como entry vía el `scripts` del tsconfig — no necesita entry explícito.
      "ignoreDependencies": ["pino-pretty"]
    },
    "packages/test-utils": {
      // Con includeEntryExports (packages/*), knip mira los exports del barrel.
      // expectGolden (golden.ts) es un helper de test de T0.1 SIN consumidor
      // todavía pero de API inminente y no rastreable por el grafo de imports:
      // está cableado en la regla vitest/expect-expect de eslint.config.ts
      // (assertFunctionNames). Ignore PUNTUAL de ese fichero — nunca un ignore
      // amplio del paquete, que re-ocultaría over-exports reales como los que
      // includeEntryExports caza en el barrel de db/test-utils.
      // `src/msw/**` YA NO se ignora: T1.3 (fast path) estrena el primer consumidor
      // de `server`/`useHttpMocks` (test del fallback transparente en @ugc/core),
      // así que knip los ve usados por el grafo de imports.
      "ignore": ["src/golden.ts"]
    },
    "packages/*": {
      // entry desde el exports map del package.json (architecture.md §7).
      // includeEntryExports: sin esto knip NO reporta exports sin consumidor en
      // ficheros-entry (el barrel `src/index.ts` lo es), y un barrel que
      // sobre-exporta símbolos "para más adelante" (viola "no anticipar") pasa el
      // gate en silencio — ocurrió en T0.2 (finding 3) y reapareció en T0.3.
      // Activarlo convierte esa clase de recurrente-solo-reviewer a cazada-por-gate.
      "includeEntryExports": true
    }
  }
}
