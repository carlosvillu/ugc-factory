{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(pnpm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git restore:*)",
      "Bash(git stash:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(docker:*)",
      "Bash(docker compose:*)",
      "Bash(curl:*)",
      "Bash(psql:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(chmod:*)",
      "Bash(tee:*)",
      "Bash(shasum:*)",
      "Bash(wc:*)",
      "Bash(jq:*)",
      "Bash(python3:*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Read(.env.test.local)",
      "Read(**/.env.local)",
      "Read(**/.env.*.local)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/guard-planning.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
