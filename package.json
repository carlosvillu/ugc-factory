{
  "name": "ugc-factory",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @ugc/web --filter @ugc/worker dev",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit && pnpm -r --parallel typecheck",
    "knip": "knip",
    "prepare": "lefthook install",
    "test": "vitest run --project '*:unit' --project '*:integration'",
    "test:unit": "vitest run --project '*:unit'",
    "test:integration": "vitest run --project '*:integration'",
    "test:e2e": "echo 'test:e2e DESHABILITADO hasta T0.4: @ugc/web aun no define test:e2e (Playwright llega con el login); sin este guard, pnpm --filter sale 0 en falso verde' && exit 1",
    "test:live": "echo 'test:live DESHABILITADO hasta T1.8: el tier live exige el guard de presupuesto @ugc/test-utils/live-budget (LIVE_BUDGET_USD) — desviacion deliberada de stack-setup.md §6 para no gastar dinero SIN limite' && exit 1",
    "test:media": "RUN_MEDIA=1 vitest run --project 'worker:media'",
    "test:watch": "vitest --project '*:unit'",
    "gate": "pnpm lint && pnpm typecheck && pnpm format:check && pnpm knip && pnpm test"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/node": "catalog:",
    "@ugc/test-utils": "workspace:*",
    "@vitest/eslint-plugin": "^1.6.21",
    "eslint": "^9.39.0",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-drizzle": "^0.2.3",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-playwright": "^2.10.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jiti": "^2.7.0",
    "knip": "^6.25.0",
    "lefthook": "^2.1.9",
    "prettier": "^3.9.4",
    "typescript": "catalog:",
    "typescript-eslint": "^8.63.0",
    "vitest": "catalog:"
  }
}
