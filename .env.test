# Entorno de TEST (committeado — stack-setup.md §7). NO contiene ningún secreto
# real: la suite estándar (`pnpm test`) es hermética (sin red real, sin BD
# compartida, sin gastar dinero). `.env.test.local` (gitignored) aporta las
# claves reales SOLO para `pnpm test:live` y gana sobre este fichero.
#
# Lo carga @ugc/test-utils/setup-env (setupFile universal de cada proyecto vitest).

NODE_ENV=test
LOG_LEVEL=silent

# APP_MASTER_KEY FALSA (T0.4): firma las cookies de sesión. Los unit de session
# inyectan su propia key con setMasterKeyForTests; este valor sirve a los tests de
# integración que ejercitan el login real. No es un secreto — es un literal de test.
APP_MASTER_KEY=test-app-master-key-not-a-secret

# DATABASE_URL está deliberadamente AUSENTE: la connection string de integración
# la fabrica Testcontainers y viaja por provide/inject (llega en T0.3), nunca por
# env — así es imposible que una suite apunte por accidente a una BD real. En los
# tests unit del ping (health), su ausencia es justo el camino de degradación
# db:false que se prueba.

# Claves FALSAS de proveedores: se añaden en la tarea que estrena cada cliente
# (FAL_KEY/ANTHROPIC_API_KEY/… en F1, APP_MASTER_KEY en T0.14). Añadirlas antes
# sería env muerto que knip/os no vigilan y nadie consume.

# Techo de gasto por RUN del tier live (`pnpm test:live`), en dolares. Lo aplica el guard
# `spendBudget()` de @ugc/test-utils/live-budget (T1.8, external-apis.md §8): cada test live
# declara su coste estimado ANTES de la llamada de pago y el run aborta si se pasaria del techo.
# La suite estandar (`pnpm test`) NO gasta nada y no lee esta variable.
#
# 0,50 -> 0,90 al entrar el test de coste sobre PAGINA REAL (T1.8 FIX C) y al pasar las
# declaraciones a coste EN FRIO. Suma declarada: 0,841 (0,001 + 0,27 + 0,14 + 0,14 + 0,29).
#
# Las declaraciones de `spendBudget()` son TECHOS, no gasto real: se dimensionan sobre el coste en
# FRIO (el honesto: la cache ephemeral dura ~5 min, asi que en produccion la mayoria de llamadas
# pagan la ESCRITURA) con un margen de 1,5x que absorbe UN reintento. No se declara el peor caso
# patologico (reintento en las cuatro sintesis = ~$1,90): un techo tan flojo no protege de nada.
# El gasto REAL de una vuelta completa ronda $0,45-0,55.
LIVE_BUDGET_USD=0.90
